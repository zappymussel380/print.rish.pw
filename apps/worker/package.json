{
  "name": "@print/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@print/db": "workspace:*",
    "@print/geometry": "workspace:*",
    "@print/shared": "workspace:*",
    "bullmq": "^5.34.8",
    "fflate": "^0.8.2",
    "ioredis": "^5.4.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.25.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
