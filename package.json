{
  "name": "print-rish-pw",
  "version": "1.0.0",
  "private": true,
  "description": "Instant 3D-printing quotation system for print.rish.pw",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @print/web --filter @print/worker dev",
    "build": "pnpm --filter @print/db generate && pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @print/db migrate:dev",
    "db:generate": "pnpm --filter @print/db generate"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.20",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.64.0"
  }
}
