# print.rish.pw — environment template.
# Copy to `.env`, fill in real values. `.env` is git-ignored; never commit it.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Public origin of the app (used for CSRF origin checks, links in PDFs/emails).
APP_ORIGIN=https://print.rish.pw

# Postgres (the compose file wires these into the postgres container too).
POSTGRES_USER=print
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=print
DATABASE_URL=postgresql://print:change-me-long-random@postgres:5432/print

# Redis
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
# 32+ byte random string; signs session cookies (admin + anonymous quote session).
#   openssl rand -hex 32
SESSION_SECRET=

# bcrypt hash of the admin dashboard password. Generate with:
#   pnpm --filter @print/web hash-password 'your-password-here'
# IMPORTANT: Docker Compose interpolates this file, and bcrypt hashes contain
# '$'. When deploying with docker-compose.yml, DOUBLE every '$' to '$$' here,
# e.g. $2a$12$abc… becomes $$2a$$12$$abc…  (the container then receives the
# correct single-'$' hash). For plain `pnpm dev` (no compose) leave it single.
ADMIN_PASSWORD_HASH=

# ---------------------------------------------------------------------------
# Business configuration
# ---------------------------------------------------------------------------
# WhatsApp number for quotation handoff, international format WITHOUT '+',
# e.g. 919876543210 for an Indian number.
WHATSAPP_NUMBER=

# Contact page details
CONTACT_EMAIL=hello@rish.pw
BUSINESS_HOURS=Mon–Sat, 10:00–19:00 IST
# Optional: full Google Maps embed URL (https://www.google.com/maps/embed?pb=...).
# Leave empty to hide the map.
GOOGLE_MAPS_EMBED_URL=

# ---------------------------------------------------------------------------
# Files & retention
# ---------------------------------------------------------------------------
# Where uploads/PDFs live INSIDE containers (named volumes; keep defaults).
UPLOAD_DIR=/data/uploads
PDF_DIR=/data/pdfs
# Per-file upload cap, in megabytes.
MAX_UPLOAD_MB=100
# Max models per quote session.
MAX_MODELS_PER_SESSION=20
# Hours to keep uploads that were never attached to a submitted quotation.
UPLOAD_RETENTION_HOURS=48
# Days to keep model files of completed/cancelled quotations (DB rows + PDFs are kept).
FILE_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Worker
# ---------------------------------------------------------------------------
# Parallel OrcaSlicer processes. 2 is right for a 6-core host; raise with care.
WORKER_CONCURRENCY=2
# Hard kill for a single slice, in seconds.
SLICE_TIMEOUT_SECONDS=180
# Thumbnail render resolution (square PNG, px).
THUMB_SIZE=512
# The following have safe defaults baked into the worker image; override only if
# you relocate the AppImage or profiles:
#   ORCA_BIN=/opt/orca/AppRun
#   PROFILES_DIR=<worker>/profiles
#   SLICE_WORK_DIR=/tmp/slice-jobs
