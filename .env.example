# print.rish.pw — environment template.
# Copy to `.env`, fill in real values. `.env` is git-ignored; never commit it.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Public origin of the app (used for CSRF origin checks, links in PDFs/emails).
APP_ORIGIN=https://print.rish.pw

# Host address the compose proxy's port 8080 binds to. Defaults to 127.0.0.1
# (loopback only — unreachable from other machines). For production set this to
# the host's Tailscale IP so the VPS nginx can reach the stack over the tailnet.
# Never set it to 0.0.0.0.
#PROXY_BIND=100.x.y.z

# REQUIRED: exact source address the compose proxy observes for the outer edge
# proxy (its tailnet IP, NAT address, or subnet-router address). Accepted forms
# are one IPv4 host with no prefix or /32, or one unbracketed IPv6 host with no
# prefix or /128. Broad subnets, hostnames, lists, and config syntax are rejected
# before nginx starts. The port-8080 firewall must allow this same single source;
# compose nginx also returns 403 to every other transport peer.
TRUSTED_PROXY_CIDR=

# Postgres schema owner. Only the short-lived `migrate` service receives this
# credential. The migration service creates/updates the two runtime roles from
# the URLs below and grants them only the tables they need.
POSTGRES_USER=print_owner
POSTGRES_PASSWORD=change-me-owner-long-random
POSTGRES_DB=print
MIGRATION_DATABASE_URL=postgresql://print_owner:change-me-owner-long-random@postgres:5432/print
DATABASE_URL=postgresql://print_web:change-me-web-long-random@postgres:5432/print
WORKER_DATABASE_URL=postgresql://print_worker:change-me-worker-long-random@postgres:5432/print

# Redis
REDIS_PASSWORD=change-me-long-random
REDIS_URL=redis://:change-me-long-random@redis:6379

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
# 32+ byte random string; signs session cookies (admin + anonymous quote session).
#   openssl rand -hex 32
SESSION_SECRET=

# bcrypt hash of the admin dashboard password. Generate with:
#   pnpm --filter @print/web hash-password
# The script prompts without exposing the password in process listings or shell
# history. It requires 12 characters and rejects input above bcrypt's 72-byte
# effective limit.
# IMPORTANT: Docker Compose interpolates this file, and bcrypt hashes contain
# '$'. When deploying with docker-compose.yml, DOUBLE every '$' to '$$' here,
# e.g. $2a$12$abc… becomes $$2a$$12$$abc…  (the container then receives the
# correct single-'$' hash). For plain `pnpm dev` (no compose) leave it single.
ADMIN_PASSWORD_HASH=

# ---------------------------------------------------------------------------
# Business configuration
# ---------------------------------------------------------------------------
# WhatsApp number for quotation handoff, international format WITHOUT '+'
# (ISD code + number), e.g. 919876543210 for an Indian number.
WHATSAPP_NUMBER=919876543210

# Contact page details
CONTACT_EMAIL=you@example.com
# Optional: full Google Maps embed URL (https://www.google.com/maps/embed?pb=...).
# Leave empty to hide the map.
GOOGLE_MAPS_EMBED_URL=

# ---------------------------------------------------------------------------
# Contact form → email (Resend). The /api/contact route posts messages here.
# Without RESEND_API_KEY + MAIL_TO the form returns a "not configured" error.
# ---------------------------------------------------------------------------
# Resend API key: https://resend.com/api-keys  (can reuse the rish.pw account).
RESEND_API_KEY=
# Where contact-form messages are delivered.
MAIL_TO=
# From address — must be a verified Resend domain sender.
CONTACT_FROM=print.rish.pw <contact@rish.pw>

# ---------------------------------------------------------------------------
# Telegram new-order notifications and PII-free operator alerts (optional).
# If either value is empty, checkout still works and no Telegram message is sent.
# Create a bot with @BotFather, send it a message/add it to a private chat, then
# use the chat id as TELEGRAM_CHAT_ID.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: Telegram forum topic/thread id for group topics.
#TELEGRAM_MESSAGE_THREAD_ID=

# ---------------------------------------------------------------------------
# Shiprocket rate calculator (shipping estimates on the quote page).
# The /api/shipping route logs in and calls courier serviceability.
# Without SHIPROCKET_EMAIL + SHIPROCKET_PASSWORD it returns "not configured".
#
# IMPORTANT: these must be *API-user* credentials, NOT your normal dashboard
# login. Create them in Shiprocket → Settings → API → Configure → "Create an
# API user". Using the dashboard login makes /auth/login return
# 403 "Access forbidden" (API access isn't enabled on that user).
# ---------------------------------------------------------------------------
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Origin/pickup pincode (the workshop). Set this to your own; defaults to
# 781001 (Guwahati GPO).
SHIPROCKET_PICKUP_PINCODE=781001

# ---------------------------------------------------------------------------
# Files & retention
# ---------------------------------------------------------------------------
# Where uploads/PDFs live INSIDE containers (named volumes; keep defaults).
UPLOAD_DIR=/data/uploads
PDF_DIR=/data/pdfs
# Per-file upload cap, in megabytes.
MAX_UPLOAD_MB=300
# Persistent files held by one active anonymous quote session.
MAX_SESSION_UPLOAD_MB=900
# Per-IP upload bytes accepted in one 10-minute window.
UPLOAD_WINDOW_MB=900
# Per-IP model bytes downloaded in one 10-minute window.
DOWNLOAD_WINDOW_MB=1200
# Stop accepting uploads before the data filesystem is completely full.
STORAGE_RESERVE_MB=2048
# Host/LXC bind paths used only with docker-compose.vault.yml.
#PRINT_DB_DIR=/srv/print-data/postgres
#PRINT_UPLOAD_DIR=/srv/print-data/files/uploads
#PRINT_PDF_DIR=/srv/print-data/files/pdfs
#PRINT_REDIS_DIR=/srv/print-data/redis
# Max models per quote session.
MAX_MODELS_PER_SESSION=20
# Hours to keep uploads that were never attached to a submitted quotation.
UPLOAD_RETENTION_HOURS=48
# Days to keep model files after every referencing quotation is terminal and
# older than this window.
FILE_RETENTION_DAYS=30
# Deletion threshold in days after the last update to a completed, delivered,
# or cancelled quotation (maximum 90; a larger value is capped). The sweep
# deletes quotation rows (including customer contact and address fields), PDFs,
# and models that become unreferenced; non-terminal quotations never age out.
QUOTATION_RETENTION_DAYS=90

# ---------------------------------------------------------------------------
# Worker
# ---------------------------------------------------------------------------
# Parallel OrcaSlicer processes. 2 is right for a 6-core host; raise with care.
WORKER_CONCURRENCY=2
# Hard kill for a single slice, in seconds.
SLICE_TIMEOUT_SECONDS=180
# Thumbnail render resolution (square PNG, px).
THUMB_SIZE=512
LOG_LEVEL=info
# CI/development HTTP-flow harness only. Exact `true` requires NODE_ENV to be
# explicitly `development` or `test`; worker startup refuses it otherwise.
# Synthetic results can poison a persistent slice cache, so use only disposable
# integration PostgreSQL/Redis stores. This flag is not forwarded by Compose.
#STUB_SLICER=false
# The following have safe defaults baked into the worker image; override only if
# you relocate the AppImage or profiles:
#   ORCA_BIN=/opt/orca/AppRun
#   PROFILES_DIR=<worker>/profiles
#   SLICE_WORK_DIR=/tmp/slice-jobs
